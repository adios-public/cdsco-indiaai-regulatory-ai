# No external API key required — all inference runs locally via Ollama / AIKosh

# Ollama endpoint (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Model routing
# default_model  — SAE classification, completeness, inspection
# powerful_model — summarisation, long-form report generation
DEFAULT_MODEL=gajendra:latest
POWERFUL_MODEL=qwen3.6:latest

# API settings
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Anonymisation
ANONYMISATION_SALT=change-this-to-a-random-secret
PSEUDO_TOKEN_PREFIX=TOK

# Logging
LOG_LEVEL=INFO
