# Ollama / AIKosh local inference
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gajendra:latest
POWERFUL_MODEL=qwen3.6:latest
EMBED_MODEL=nomic-embed-text:latest

# adios-inference gateway (HuggingFace models + Ollama proxy)
INFERENCE_GATEWAY_URL=http://localhost:8010

# Rust API
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Anonymisation
ANONYMISATION_SALT=change-this-to-a-random-secret
PSEUDO_TOKEN_PREFIX=TOK

RUST_LOG=info,adios_regulatory_ai=debug
