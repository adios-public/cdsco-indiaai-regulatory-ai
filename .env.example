# All inference is local via Ollama/AIKosh — no external API key needed

OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gajendra:latest
POWERFUL_MODEL=qwen3.6:latest
EMBED_MODEL=nomic-embed-text:latest

API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

ANONYMISATION_SALT=change-this-to-a-random-secret
PSEUDO_TOKEN_PREFIX=TOK

RUST_LOG=info,adios_regulatory_ai=debug
