# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# API settings
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Anonymisation settings
ANONYMISATION_SALT=change-this-to-a-random-secret
PSEUDO_TOKEN_PREFIX=TOK

# Model settings
# Options: claude-sonnet-4-6 | claude-haiku-4-5-20251001
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# Logging
LOG_LEVEL=INFO
